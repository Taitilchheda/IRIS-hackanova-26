# IRIS Environment Variables
# Copy this to .env and fill in the values

# --- LLM Providers ---
# At least one is required for Cognitive Hub (Chat/Parsing)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Optional Tools ---
# Alpaca is used for live execution steps (if enabled)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Server Config ---
PORT=8000
LOG_LEVEL=INFO

# --- Database ---
# Default is local SQLite
DB_URL=sqlite:///./iris.db
JWT_SECRET=pitch-ready-iris-2026
